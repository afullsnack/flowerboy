---
import EmailDialog from "../components/EmailDialog.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <EmailDialog />
  </body>
</html>
