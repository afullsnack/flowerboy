---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Graxie's Preorder & Importation — Join the Telegram Channel">
  <link
    slot="head"
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700;800&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />

  <style is:global>
    :root{
      --navy:#1B3A6B;
      --blue:#2F5DA8;
      --orange-1:#F6B042;
      --orange-2:#E2691F;
      --bg:#F7FAFC;
      --slate:#334155;
      --slate-light:#5A6B85;
      --white:#ffffff;
    }
    *{box-sizing:border-box; margin:0; padding:0;}
    body{
      font-family:'Inter', sans-serif;
      background:var(--bg);
      color:var(--slate);
      line-height:1.5;
    }
    .wrap{max-width:480px; margin:0 auto; padding:0 20px;}

    /* ===== HERO ===== */
    .hero{
      background:linear-gradient(160deg, var(--navy) 0%, var(--blue) 100%);
      color:var(--white);
      padding:36px 20px 50px;
      position:relative;
      overflow:hidden;
    }
    .hero::after{
      content:"";
      position:absolute;
      top:-60px; right:-80px;
      width:260px; height:260px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(246,176,66,0.35), transparent 70%);
    }
    .brand{
      display:flex;
      align-items:center;
      gap:10px;
      font-family:'Poppins', sans-serif;
      font-weight:700;
      font-size:15px;
      letter-spacing:0.5px;
      margin-bottom:28px;
      position:relative; z-index:1;
    }
    .brand .mark{
      width:34px; height:34px;
      flex-shrink:0;
    }
    .eyebrow{
      display:inline-block;
      background:rgba(255,255,255,0.14);
      border:1px solid rgba(255,255,255,0.25);
      border-radius:999px;
      font-size:12px;
      font-weight:600;
      letter-spacing:0.4px;
      padding:6px 14px;
      margin-bottom:16px;
      position:relative; z-index:1;
    }
    .hero h1{
      font-family:'Poppins', sans-serif;
      font-weight:800;
      font-size:30px;
      line-height:1.25;
      margin-bottom:12px;
      position:relative; z-index:1;
    }
    .hero h1 span{color:var(--orange-1);}
    .hero p{
      font-size:15px;
      color:rgba(255,255,255,0.85);
      max-width:380px;
      position:relative; z-index:1;
    }

    /* ===== TICKET / PRICE CARD ===== */
    .ticket{
      background:var(--white);
      border-radius:18px;
      margin:-30px 0 28px;
      position:relative;
      z-index:2;
      box-shadow:0 18px 40px -12px rgba(27,58,107,0.35);
      overflow:hidden;
    }
    .ticket-top{
      padding:22px 22px 16px;
      display:flex;
      align-items:center;
      justify-content:space-between;
    }
    .ticket-label{
      font-size:12px;
      font-weight:600;
      letter-spacing:0.6px;
      color:var(--slate-light);
      text-transform:uppercase;
    }
    .price{
      font-family:'Poppins', sans-serif;
      font-weight:800;
      font-size:34px;
      color:var(--navy);
    }
    .price sup{font-size:16px; top:-14px;}
    .perk{font-size:12.5px; color:var(--slate-light); margin-top:2px;}
    .ticket-divider{
      position:relative;
      border-top:2px dashed #E2E8F0;
      margin:0 22px;
    }
    .ticket-divider::before, .ticket-divider::after{
      content:"";
      position:absolute;
      top:-10px;
      width:20px; height:20px;
      background:var(--bg);
      border-radius:50%;
    }
    .ticket-divider::before{left:-32px;}
    .ticket-divider::after{right:-32px;}
    .ticket-bottom{padding:18px 22px 22px;}
    .ticket-bottom ul{list-style:none;}
    .ticket-bottom li{
      font-size:14px;
      display:flex;
      gap:10px;
      margin-bottom:10px;
      color:var(--slate);
    }
    .ticket-bottom li::before{
      content:"✓";
      color:var(--orange-2);
      font-weight:700;
      flex-shrink:0;
    }
    .cta-btn{
      width:100%;
      margin-top:10px;
      background:linear-gradient(135deg, var(--orange-1), var(--orange-2));
      color:var(--white);
      border:none;
      border-radius:12px;
      padding:16px;
      font-family:'Poppins', sans-serif;
      font-weight:700;
      font-size:16px;
      cursor:pointer;
      box-shadow:0 10px 20px -6px rgba(226,105,31,0.55);
    }
    .cta-btn:active{transform:translateY(1px);}
    .secure-note{
      text-align:center;
      font-size:12px;
      color:var(--slate-light);
      margin-top:10px;
    }

    /* ===== HOW IT WORKS ===== */
    section{padding:8px 0 32px;}
    .section-title{
      font-family:'Poppins', sans-serif;
      font-weight:700;
      font-size:18px;
      color:var(--navy);
      margin-bottom:16px;
    }
    .steps{display:flex; flex-direction:column; gap:14px;}
    .step{
      display:flex;
      gap:14px;
      align-items:flex-start;
      background:var(--white);
      border-radius:12px;
      padding:14px 16px;
      border:1px solid #E7ECF3;
    }
    .step-num{
      flex-shrink:0;
      width:30px; height:30px;
      border-radius:50%;
      background:var(--navy);
      color:var(--white);
      font-weight:700;
      font-size:13px;
      display:flex; align-items:center; justify-content:center;
    }
    .step h4{font-size:14.5px; font-weight:600; color:var(--slate); margin-bottom:3px;}
    .step p{font-size:13px; color:var(--slate-light);}

    /* ===== WHO IT'S FOR ===== */
    .audience{
      background:var(--white);
      border-radius:12px;
      padding:18px 16px;
      border:1px solid #E7ECF3;
      font-size:13.5px;
      color:var(--slate-light);
    }
    .audience b{color:var(--navy);}

    /* ===== FOOTER ===== */
    footer{
      text-align:center;
      padding:20px 20px 36px;
      font-size:12px;
      color:var(--slate-light);
    }
    footer a{color:var(--blue); text-decoration:none;}
  </style>

  <div class="hero">
    <div class="wrap">
      <div class="brand">
        <svg class="mark" viewBox="0 0 240 220" xmlns="http://www.w3.org/2000/svg">
          <path d="M -45 100 C -90 0, -20 -120, 100 -150 C 160 -165, 210 -150, 225 -120"
                transform="translate(20,140)"
                fill="none" stroke="#F6B042" stroke-width="16" stroke-linecap="round"/>
          <g transform="translate(60,90)">
            <path d="M -40 0 L 25 0 L 55 35 L 55 70 L -40 70 Z" fill="#ffffff"/>
            <rect x="55" y="-25" width="85" height="95" fill="#ffffff"/>
            <circle cx="-5" cy="78" r="20" fill="#1B3A6B"/>
            <circle cx="100" cy="78" r="20" fill="#1B3A6B"/>
          </g>
        </svg>
        GRAXIE'S
      </div>

      <span class="eyebrow">🇳🇬 Preorder & Importation</span>
      <h1>Stop missing out on <span>international drops</span> before they sell out.</h1>
      <p>Join Graxie's private Telegram channel for early access to preorder slots, real shipping updates, and import deals you won't find on the public page.</p>
    </div>
  </div>

  <div class="wrap">

    <!-- TICKET -->
    <div class="ticket">
      <div class="ticket-top">
        <div>
          <div class="ticket-label">Channel Access</div>
          <div class="price"><sup>₦</sup>30,000</div>
          <div class="perk">One-time payment · Lifetime access</div>
        </div>
      </div>
      <div class="ticket-divider"></div>
      <div class="ticket-bottom">
        <ul>
          <li>Instant Telegram invite link after payment</li>
          <li>First access to new preorder batches</li>
          <li>Real-time shipping & customs updates</li>
          <li>Direct line to Graxie's team for questions</li>
        </ul>
        <button class="cta-btn" id="payBtn">Pay ₦30,000 &amp; Get My Invite</button>
        <div class="secure-note">🔒 Secure payment via Paystack</div>
      </div>
    </div>

    <!-- HOW IT WORKS -->
    <section>
      <div class="section-title">How it works</div>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <div>
            <h4>Tap "Pay ₦30,000"</h4>
            <p>You'll be taken straight to a secure Paystack checkout — card, bank transfer, or USSD.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div>
            <h4>Payment confirms instantly</h4>
            <p>No waiting around — the moment it goes through, you're cleared for access.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div>
            <h4>Get your Telegram link</h4>
            <p>Your one-time invite link appears on screen and is sent to your email.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- AUDIENCE -->
    <section style="padding-top:0;">
      <div class="audience">
        <b>Who this is for:</b> shoppers who want first dibs on preorders and imported items, and are tired of missing restocks because they found out too late.
      </div>
    </section>

    <footer>
      Graxie's Preorder & Importation Company<br>
      Questions before you pay? <a href="https://wa.me/2347077191980" target="_blank">Message us on WhatsApp</a>
    </footer>
  </div>

  <script is:inline src="https://js.paystack.co/v1/inline.js"></script>
  <script is:inline>
    document.getElementById('payBtn').addEventListener('click', function () {
      var handler = PaystackPop.setup({
        key: 'pk_test_7ab8e99537ac12c9e30933d7d185af42c1d892b7',
        email: 'customer@example.com', // TODO: collect this from a form field before charging, see note below
        amount: 3000000, // amount in kobo => ₦30,000
        currency: 'NGN',
        callback: function (response) {
          // Payment succeeded — show the Telegram link
          document.querySelector('.ticket-bottom').innerHTML =
            '<p style="font-weight:700;color:#1B3A6B;margin-bottom:10px;">✅ Payment received!</p>' +
            '<p style="font-size:14px;margin-bottom:14px;">Tap below to join the channel now.</p>' +
            '<a href="https://t.me/preoderwithgraxie" target="_blank" style="display:block;text-align:center;background:#1B3A6B;color:#fff;padding:14px;border-radius:12px;font-weight:700;text-decoration:none;">Join Telegram Channel</a>';
        },
        onClose: function () {
          // user closed the popup without paying
        }
      });
      handler.openIframe();
    });
  </script>
</BaseLayout>
